# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
LLM_PROVIDER=openai

# Ollama (only if LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/resume_intel

# ── Redis (required — pipeline results, WebSocket pub/sub, session state) ─────
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=3600

# ── FAISS ─────────────────────────────────────────────────────────────────────
FAISS_INDEX_DIR=./data/faiss_indices

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_PORT=8000

# ── LinkedIn OAuth (provide to enable live profile sync) ──────────────────────
# Register at https://www.linkedin.com/developers/apps
# Scopes: r_liteprofile, r_emailaddress, r_member_social
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── GitHub (provide to enable live repo sync) ─────────────────────────────────
# Fine-grained token: https://github.com/settings/tokens
# Scopes: read:user, read:repo
GITHUB_ACCESS_TOKEN=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
